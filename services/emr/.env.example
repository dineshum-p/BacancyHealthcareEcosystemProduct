# Copy to .env for local runs against docker-compose.test.yml.
#
# IMPORTANT (schema-per-tenant, shared cluster): in a real deployment this
# service must point at the SAME Postgres cluster/database as services/tenant
# so it can read the shared `public.tenants` registry and bind connections to
# each tenant's existing schema. docker-compose.test.yml here only spins up an
# isolated instance for this service's own local/CI testing convenience.
DATABASE_URL=postgres://emr_service:emr_service@localhost:5547/emr_service
DB_HOST=localhost
DB_PORT=5547
DB_USER=emr_service
DB_PASSWORD=emr_service
DB_NAME=emr_service

# JWT access token verification secret (mirrors services/tenant's BAC-8 and
# services/notification's BAC-9 pattern). services/emr never issues tokens --
# only services/auth does -- but it independently verifies them, so this MUST
# be the exact same value services/auth signs with. MUST be overridden with a
# strong random value outside local dev/test (a dev-only fallback is baked
# into src/config/auth.config.ts so the service still boots without a .env
# file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me

# Domain-event publishing (BAC-15, AC4): encounter.created is published via a
# KafkaEventPublisherAdapter port when KAFKA_PRODUCER_ENABLED=true, mirroring
# services/patient's BAC-14 KAFKA_PRODUCER_ENABLED opt-in convention -- no
# real Kafka broker is provisioned anywhere in this repo/sandbox, so this
# defaults to false everywhere (including production) until an operator
# explicitly opts in against a real, provisioned Kafka cluster. When
# disabled, a NoopDomainEventPublisher still runs the exact same publish
# call path (proving the wiring is correct), it just does not attempt any
# network I/O.
KAFKA_PRODUCER_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_ENCOUNTER_CREATED_TOPIC=encounter.created

# PHI column-encryption key (BAC-44): PatientProfileRepository passes this to
# Postgres's pgcrypto extension (pgp_sym_encrypt/pgp_sym_decrypt) to encrypt/
# decrypt the patient_profiles.allergies/chronic_conditions columns at the
# COLUMN level, in addition to whatever disk-level encryption already applies.
# MUST be overridden with a strong random value outside local dev/test (a
# dev-only fallback is baked into src/config/pgcrypto.config.ts so the service
# still boots without a .env file). Rotating this key makes every
# previously-encrypted value undecryptable -- there is no key-rotation/
# re-encryption tooling in this ticket's scope.
PGCRYPTO_COLUMN_KEY=dev-insecure-column-encryption-key-change-me
