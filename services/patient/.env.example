# Copy to .env for local runs against docker-compose.test.yml.
#
# IMPORTANT (schema-per-tenant, shared cluster): in a real deployment this
# service must point at the SAME Postgres cluster/database as services/tenant
# so it can read the shared `public.tenants` registry and bind connections to
# each tenant's existing schema. docker-compose.test.yml here only spins up an
# isolated instance for this service's own local/CI testing convenience.
DATABASE_URL=postgres://patient_service:patient_service@localhost:5549/patient_service
DB_HOST=localhost
DB_PORT=5549
DB_USER=patient_service
DB_PASSWORD=patient_service
DB_NAME=patient_service

# JWT access token verification secret (mirrors services/tenant's BAC-8,
# services/notification's BAC-9, services/emr's BAC-10, and
# services/billing's BAC-11 pattern). services/patient never issues tokens --
# only services/auth does -- but it independently verifies them, so this MUST
# be the exact same value services/auth signs with. MUST be overridden with a
# strong random value outside local dev/test (a dev-only fallback is baked
# into src/config/auth.config.ts so the service still boots without a .env
# file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me

# CORS: apps/web (BAC-17, a future ticket) calls this service directly from
# the browser to register/search patients. Comma-separated list of allowed
# origins; unset falls back to a small set of common local dev origins (see
# src/config/cors.config.ts).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Domain-event publishing (BAC-14, AC4): patient.created is published via a
# KafkaEventPublisherAdapter port when KAFKA_PRODUCER_ENABLED=true, mirroring
# services/notification's BAC-9 KAFKA_CONSUMER_ENABLED opt-in convention --
# no real Kafka broker is provisioned anywhere in this repo/sandbox, so this
# defaults to false everywhere (including production) until an operator
# explicitly opts in against a real, provisioned Kafka cluster. When
# disabled, a NoopDomainEventPublisher still runs the exact same publish
# call path (proving the wiring is correct), it just does not attempt any
# network I/O.
KAFKA_PRODUCER_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_PATIENT_CREATED_TOPIC=patient.created
