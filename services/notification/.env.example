# Copy to .env for local runs against docker-compose.test.yml.
#
# IMPORTANT (schema-per-tenant, shared cluster): in a real deployment this
# service must point at the SAME Postgres cluster/database as services/tenant
# so it can read the shared `public.tenants` registry and bind connections to
# each tenant's existing schema. docker-compose.test.yml here only spins up an
# isolated instance for this service's own local/CI testing convenience.
DATABASE_URL=postgres://notification_service:notification_service@localhost:5546/notification_service
DB_HOST=localhost
DB_PORT=5546
DB_USER=notification_service
DB_PASSWORD=notification_service
DB_NAME=notification_service

# JWT access token verification secret (mirrors services/tenant's BAC-8
# pattern). services/notification never issues tokens -- only services/auth
# does -- but it independently verifies them, so this MUST be the exact same
# value services/auth signs with. MUST be overridden with a strong random
# value outside local dev/test (a dev-only fallback is baked into
# src/config/auth.config.ts so the service still boots without a .env file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me

# Shared secret checked by InternalServiceGuard on POST /notifications/internal
# (BAC-12) -- must be the SAME value services/tenant is configured to send
# as its X-Internal-Service-Key header. MUST be overridden with a strong
# random value outside local dev/test (a dev-only fallback is baked into
# src/config/internal-service.config.ts so the service still boots without
# a .env file).
INTERNAL_SERVICE_KEY=dev-insecure-internal-service-key-change-me

# --- Retry / backoff (BAC-9, AC3) ---
# Total attempts (including the first) before a notification is marked
# `failed`. Default: 3.
NOTIFICATION_MAX_ATTEMPTS=3
# Base delay, in milliseconds, for exponential backoff between retries:
# attempt N waits NOTIFICATION_BACKOFF_BASE_MS * 2^(N-1). Default: 200ms.
NOTIFICATION_BACKOFF_BASE_MS=200
# Bound, in milliseconds, on a SINGLE delivery attempt -- a hung/never-
# resolving provider adapter call (vendor outage, DNS black-hole, etc.)
# cannot freeze the retry loop past this. Treated as an ordinary transient
# failure (counts toward attempts/triggers backoff/retry). Default: 8000ms.
NOTIFICATION_ATTEMPT_TIMEOUT_MS=8000

# --- Provider adapter selection (BAC-9, AC1/AC3) ---
# 'fake' (default, and the ONLY mode ever exercised by this repo's automated
# tests) or 'real' (wires up the Twilio/SendGrid-shaped adapters below).
# Deliberately defaults to 'fake' everywhere -- including production -- until
# real vendor credentials are provisioned AND this is explicitly switched by
# an operator; this prevents this service from ever silently attempting a
# real network call for lack of an explicit env var.
NOTIFICATION_PROVIDER_MODE=fake
# Required only when NOTIFICATION_PROVIDER_MODE=real:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- Domain event consumption (BAC-9, AC4) ---
# No real Kafka broker exists anywhere in this repo/sandbox. The consumer is
# disabled by default (KAFKA_CONSUMER_ENABLED=false) so this service never
# attempts an outbound broker connection unless an operator explicitly opts
# in against a real, provisioned Kafka cluster. See
# src/notifications/events/README.md for the full scope boundary.
KAFKA_CONSUMER_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_USER_REGISTERED_TOPIC=user.registered
KAFKA_CONSUMER_GROUP=notification-service
