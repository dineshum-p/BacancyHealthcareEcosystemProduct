# Copy to .env for local runs against docker-compose.test.yml.
#
# IMPORTANT (schema-per-tenant, shared cluster): in a real deployment this
# service must point at the SAME Postgres cluster/database as services/tenant
# so it can read the shared `public.tenants` registry (including each
# tenant's billing `plan`) and bind connections to each tenant's existing
# schema. docker-compose.test.yml here only spins up an isolated instance for
# this service's own local/CI testing convenience.
DATABASE_URL=postgres://billing_service:billing_service@localhost:5548/billing_service
DB_HOST=localhost
DB_PORT=5548
DB_USER=billing_service
DB_PASSWORD=billing_service
DB_NAME=billing_service

# JWT access token verification secret (mirrors services/tenant's BAC-8,
# services/notification's BAC-9, and services/emr's BAC-10 pattern).
# services/billing never issues tokens -- only services/auth does -- but it
# independently verifies them, so this MUST be the exact same value
# services/auth signs with. MUST be overridden with a strong random value
# outside local dev/test (a dev-only fallback is baked into
# src/config/auth.config.ts so the service still boots without a .env file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me
