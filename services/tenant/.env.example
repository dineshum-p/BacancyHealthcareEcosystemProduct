# Copy to .env for local migrations against docker-compose.test.yml
DATABASE_URL=postgres://tenant_service:tenant_service@localhost:5544/tenant_service
DB_HOST=localhost
DB_PORT=5544
DB_USER=tenant_service
DB_PASSWORD=tenant_service
DB_NAME=tenant_service

# JWT access token verification secret (BAC-8). services/tenant never issues
# tokens -- only services/auth does -- but it independently verifies them, so
# this MUST be the exact same value services/auth signs with. MUST be
# overridden with a strong random value outside local dev/test (a dev-only
# fallback is baked into src/config/auth.config.ts so the service still boots
# without a .env file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me

# --- BAC-12 onboarding orchestration (POST /tenants/onboard) ---
# Base URLs services/tenant calls into for the onboarding flow. Defaults
# match each sibling service's default local port.
AUTH_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3003
# Shared secret sent as X-Internal-Service-Key to both -- MUST equal the
# SAME value services/auth and services/notification are each configured
# with (their own INTERNAL_SERVICE_KEY). MUST be overridden with a strong
# random value outside local dev/test (a dev-only fallback is baked into
# src/onboarding/config/onboarding.config.ts so the service still boots
# without a .env file).
INTERNAL_SERVICE_KEY=dev-insecure-internal-service-key-change-me
# Bound, in milliseconds, on a single outbound call to services/auth or
# services/notification during onboarding. Default: 5000ms.
ONBOARDING_REQUEST_TIMEOUT_MS=5000
