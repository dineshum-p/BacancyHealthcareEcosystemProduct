# Copy to .env for local runs against docker-compose.test.yml.
#
# IMPORTANT (schema-per-tenant, shared cluster): in a real deployment this
# service must point at the SAME Postgres cluster/database as services/tenant
# so it can read the shared `public.tenants` registry and bind connections to
# each tenant's existing schema. docker-compose.test.yml here only spins up an
# isolated instance for this service's own local/CI testing convenience.
DATABASE_URL=postgres://scheduling_service:scheduling_service@localhost:5550/scheduling_service
DB_HOST=localhost
DB_PORT=5550
DB_USER=scheduling_service
DB_PASSWORD=scheduling_service
DB_NAME=scheduling_service

# JWT access token verification secret (mirrors services/tenant's BAC-8,
# services/notification's BAC-9, services/emr's BAC-10, services/billing's
# BAC-11, and services/patient's BAC-14 pattern). services/scheduling never
# issues tokens -- only services/auth does -- but it independently verifies
# them, so this MUST be the exact same value services/auth signs with. MUST be
# overridden with a strong random value outside local dev/test (a dev-only
# fallback is baked into src/config/auth.config.ts so the service still boots
# without a .env file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me

# CORS: apps/web calls this service directly from the browser to book/manage
# appointments. Comma-separated list of allowed origins; unset falls back to a
# small set of common local dev origins (see src/config/cors.config.ts).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CORS, subdomain-per-tenant (BAC-38, optional): if apps/web is deployed with
# one subdomain per tenant (e.g. acme-clinic.yourapp.com), set this to the
# root domain (yourapp.com) to allow EVERY tenant subdomain as a CORS origin,
# on top of (not instead of) CORS_ALLOWED_ORIGINS above. Unset (the default)
# keeps CORS_ALLOWED_ORIGINS as the only allow-list.
CORS_ALLOWED_ORIGIN_SUFFIX=

# services/notification integration (BAC-16): booking a slot sends a
# confirmation notification via a real, synchronous HTTP call to
# services/notification's POST /notifications/internal -- mirrors
# services/tenant's BAC-12 onboarding-invite client exactly (see
# src/notifications/clients/http-notification-service.client.ts). Both
# services must be configured with the SAME INTERNAL_SERVICE_KEY.
NOTIFICATION_SERVICE_URL=http://localhost:3004
INTERNAL_SERVICE_KEY=dev-insecure-internal-service-key-change-me
NOTIFICATION_REQUEST_TIMEOUT_MS=5000

# PHI column-encryption key (BAC-45): VisitIntakesRepository passes this to
# Postgres's pgcrypto extension (pgp_sym_encrypt/pgp_sym_decrypt) to encrypt/
# decrypt the visit_intakes.reason_for_visit/symptoms/
# whats_new_since_last_visit columns at the COLUMN level, in addition to
# whatever disk-level encryption already applies. Mirrors services/emr's
# BAC-44 PGCRYPTO_COLUMN_KEY exactly. MUST be overridden with a strong random
# value outside local dev/test (a dev-only fallback is baked into
# src/config/pgcrypto.config.ts so the service still boots without a .env
# file). Rotating this key makes every previously-encrypted value
# undecryptable -- there is no key-rotation/re-encryption tooling in this
# ticket's scope.
PGCRYPTO_COLUMN_KEY=dev-insecure-column-encryption-key-change-me
