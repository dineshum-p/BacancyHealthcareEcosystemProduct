# Copy to .env for local runs against docker-compose.test.yml.
#
# IMPORTANT (schema-per-tenant, shared cluster): in a real deployment this
# service must point at the SAME Postgres cluster/database as services/tenant
# so it can read the shared `public.tenants` registry and bind connections to
# each tenant's existing schema. docker-compose.test.yml here only spins up an
# isolated instance for this service's own local/CI testing convenience.
DATABASE_URL=postgres://auth_service:auth_service@localhost:5545/auth_service
DB_HOST=localhost
DB_PORT=5545
DB_USER=auth_service
DB_PASSWORD=auth_service
DB_NAME=auth_service

# JWT access token signing secret. MUST be overridden with a strong random
# value outside local dev/test (a dev-only fallback is baked into
# src/config/auth.config.ts so the service still boots without a .env file).
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me

# Token lifetimes, in seconds. Defaults: 15 minutes / 7 days.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# Key used to derive the AES-256-GCM key that encrypts TOTP secrets at rest
# (BAC-6). MUST be overridden with a strong random value outside local
# dev/test (a dev-only fallback is baked into src/config/auth.config.ts so
# the service still boots without a .env file). Unlike JWT_ACCESS_SECRET,
# this key protects data that must be DECRYPTED (not just verified) --
# rotating it invalidates every enrolled user's stored TOTP secret.
MFA_ENCRYPTION_KEY=dev-insecure-mfa-key-change-me

# Shared secret checked by InternalServiceGuard on POST /auth/admin-seed
# (BAC-12) -- must be the SAME value services/tenant is configured to send
# as its X-Internal-Service-Key header. MUST be overridden with a strong
# random value outside local dev/test (a dev-only fallback is baked into
# src/config/internal-service.config.ts so the service still boots without
# a .env file).
INTERNAL_SERVICE_KEY=dev-insecure-internal-service-key-change-me
