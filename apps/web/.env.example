# Copy to .env.local for local dev.

# services/tenant's base URL (BAC-12: Super Admin tenant onboarding
# console). Dev-only fallback (services/tenant's assigned local port -- see
# scripts/start-all-local.sh; apps/web itself owns port 3000) is baked into
# src/lib/api/tenantsApi.ts so the app still runs without this set.
NEXT_PUBLIC_TENANT_SERVICE_URL=http://localhost:3001

# services/auth's base URL (BAC-13: login + MFA challenge screen). Dev-only
# fallback (services/auth's assigned local port -- see
# scripts/start-all-local.sh) is baked into src/lib/api/authApi.ts so the app
# still runs without this set.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3002

# BAC-38: root domain for subdomain-per-tenant deployments, read by
# middleware.ts (server-side only -- deliberately NOT NEXT_PUBLIC_, unlike
# the service URLs above). When set, a request to
# <tenantSlug>.<APP_ROOT_DOMAIN>/register is rewritten internally to the
# existing /<tenantSlug>/register route, so a patient never has to type a
# workspace/tenant name. Unset (the default) makes middleware.ts a no-op --
# path-based /<tenantSlug>/register URLs keep working either way. Locally,
# *.localhost subdomains resolve to loopback in every modern browser with no
# DNS/hosts-file changes, so this is safe to try with APP_ROOT_DOMAIN=localhost.
APP_ROOT_DOMAIN=
