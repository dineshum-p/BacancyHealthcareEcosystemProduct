# Copy to .env.local for local dev.

# services/tenant's base URL (BAC-12: Super Admin tenant onboarding
# console). Dev-only fallback (services/tenant's own default port) is baked
# into src/lib/api/tenantsApi.ts so the app still runs without this set.
NEXT_PUBLIC_TENANT_SERVICE_URL=http://localhost:3000

# services/auth's base URL (BAC-13: login + MFA challenge screen). Dev-only
# fallback (services/auth's own default port) is baked into
# src/lib/api/authApi.ts so the app still runs without this set.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001
