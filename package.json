{
  "name": "hep",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.9.0",
  "workspaces": ["apps/*", "services/*", "packages/*"],
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "affected": "turbo run typecheck lint test --filter=...[origin/main]",
    "auto": "node orchestrator.mjs",
    "auto:supervised": "MODE=supervised node orchestrator.mjs",
    "auto:one": "MAX_TICKETS=1 MODE=supervised node orchestrator.mjs"
  }
}
